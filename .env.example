# Application Environment
NODE_ENV=production
APP_ENV=production
TZ=UTC

# Firebase Configuration (NEVER commit real values!)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_STORAGE_BUCKET=your_storage_bucket

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_to_secure_password
REDIS_DB=0

# Session Configuration
SESSION_LIFETIME=86400
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900

# Security Headers
SECURITY_HEADERS_ENABLED=true
# Leave empty to use the secure default from bootstrap.php (includes Firebase, Leaflet, Google Fonts)
CONTENT_SECURITY_POLICY=
X_FRAME_OPTIONS=SAMEORIGIN

# Database (if using SQL backend)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lumina
DB_USER=lumina_user
DB_PASS=secure_password

# SMTP Email Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_ENCRYPTION=tls

# File Upload Configuration
UPLOAD_MAX_SIZE=52428800
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf
UPLOAD_TEMP_DIR=/tmp

# JWT Secret (for API authentication)
JWT_SECRET=your_super_secret_jwt_key_change_this

# API Keys (if using external APIs)
GOOGLE_API_KEY=
MAPBOX_TOKEN=

# Logging
LOG_LEVEL=warning
LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

# Security Features
ENABLE_2FA=true
ENABLE_CSRF_PROTECTION=true
ENABLE_RATE_LIMITING=true
ENABLE_REQUEST_SIGNING=true

# CSP Nonce (regenerated on each request in production)
CSP_NONCE=

# Admin Email for alerts
ADMIN_EMAIL=admin@yourdomain.com
