rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function ownsDoc(id) {
      return signedIn() && uid() == id;
    }

    function ownsBusinessData(data) {
      return signedIn() && data.businessId == uid();
    }

    function ownsUserData(data) {
      return signedIn() && data.userId == uid();
    }

    function hasBusinessIdentity(data) {
      return data.name is string
        && data.category is string
        && data.ownerId is string
        && data.profileComplete is bool;
    }

    function hasAppointmentIdentity(data) {
      return data.businessId is string
        && data.date is string
        && data.time is string
        && data.status is string;
    }

    match /users/{uidParam} {
      allow read, write: if ownsDoc(uidParam);
    }

    match /businesses/{bizId} {
      allow read: if true;
      allow create: if ownsDoc(bizId)
        && hasBusinessIdentity(request.resource.data)
        && request.resource.data.ownerId == uid()
        && request.resource.data.profileComplete == false;
      allow update: if ownsDoc(bizId)
        && resource.data.ownerId == uid()
        && request.resource.data.ownerId == resource.data.ownerId
        && hasBusinessIdentity(request.resource.data);
      allow delete: if ownsDoc(bizId) && resource.data.ownerId == uid();

      match /services/{svcId} {
        allow read: if true;
        allow create: if ownsDoc(bizId);
        allow update, delete: if ownsDoc(bizId);
      }

      match /staff/{staffId} {
        allow read: if true;
        allow create: if ownsDoc(bizId);
        allow update, delete: if ownsDoc(bizId);
      }

      match /gallery/{photoId} {
        allow read: if true;
        allow create: if ownsDoc(bizId);
        allow update, delete: if ownsDoc(bizId);
      }
    }

    match /appointments/{apptId} {
      allow read: if signedIn() && (
        resource.data.userId == uid() ||
        resource.data.businessId == uid()
      );
      allow create: if signedIn()
        && hasAppointmentIdentity(request.resource.data)
        && (
          request.resource.data.userId == uid() ||
          request.resource.data.businessId == uid()
        );
      allow update: if signedIn() && (
        resource.data.userId == uid() ||
        resource.data.businessId == uid()
      ) && request.resource.data.businessId == resource.data.businessId;
      allow delete: if signedIn() && (
        resource.data.userId == uid() ||
        resource.data.businessId == uid()
      );
    }

    match /clients/{clientId} {
      allow read, update, delete: if ownsBusinessData(resource.data);
      allow create: if ownsBusinessData(request.resource.data);
    }

    match /services/{svcId} {
      allow read: if true;
      allow create: if ownsBusinessData(request.resource.data);
      allow update, delete: if ownsBusinessData(resource.data)
        && request.resource.data.businessId == resource.data.businessId;
    }

    match /staff/{staffId} {
      allow read: if true;
      allow create: if ownsBusinessData(request.resource.data);
      allow update, delete: if ownsBusinessData(resource.data)
        && request.resource.data.businessId == resource.data.businessId;
    }

    match /promotions/{promoId} {
      allow read: if true;
      allow create: if ownsBusinessData(request.resource.data);
      allow update, delete: if ownsBusinessData(resource.data)
        && request.resource.data.businessId == resource.data.businessId;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if ownsUserData(request.resource.data)
        && request.resource.data.businessId is string;
      allow update, delete: if signedIn() && (
        resource.data.userId == uid() ||
        resource.data.businessId == uid()
      );
    }

    match /portfolio/{itemId} {
      allow read: if true;
      allow create: if ownsBusinessData(request.resource.data);
      allow update, delete: if ownsBusinessData(resource.data)
        && request.resource.data.businessId == resource.data.businessId;
    }

    match /notifications/{notifId} {
      allow read, update, delete: if ownsUserData(resource.data);
      allow create: if ownsUserData(request.resource.data);
    }

    match /favorites/{favId} {
      allow read, update, delete: if ownsUserData(resource.data);
      allow create: if ownsUserData(request.resource.data)
        && request.resource.data.bizId is string;
    }

    match /claims/{claimId} {
      allow create: if ownsUserData(request.resource.data)
        && request.resource.data.businessId is string
        && request.resource.data.nip is string
        && request.resource.data.status == 'pending'
        && request.resource.data.consent == true;
      allow read: if ownsUserData(resource.data);
      allow update, delete: if false;
    }

    match /subscriptions/{uidParam} {
      allow read, write: if ownsDoc(uidParam);
    }

    match /transactions/{txId} {
      allow read: if signedIn() && resource.data.userId == uid();
      allow create: if signedIn() && request.resource.data.userId == uid();
      allow update, delete: if false;
    }

    match /refund_requests/{reqId} {
      allow create: if ownsUserData(request.resource.data);
      allow read: if ownsUserData(resource.data);
      allow update, delete: if false;
    }

    match /conversations/{convId} {
      allow read, update: if signedIn() && uid() in resource.data.participants;
      allow create: if signedIn() && uid() in request.resource.data.participants;
      match /messages/{msgId} {
        allow read, create: if signedIn();
        allow update: if signedIn();
      }
    }

    match /loyalty/{uidParam} {
      allow read, write: if ownsDoc(uidParam);
    }

    match /loyalty_history/{histId} {
      allow read: if signedIn() && resource.data.userId == uid();
      allow create: if signedIn() && request.resource.data.userId == uid();
    }

    match /loyalty_rewards/{rewardId} {
      allow read: if true;
    }

    match /loyalty_redemptions/{redId} {
      allow read, create: if ownsUserData(request.resource.data);
    }

    match /promo_codes/{codeId} {
      allow read: if true;
      allow create: if ownsBusinessData(request.resource.data);
      allow update, delete: if ownsBusinessData(resource.data);
    }

    match /promo_usage/{usageId} {
      allow read, create: if signedIn();
    }

    match /sms_reminders/{remId} {
      allow read, create, delete: if signedIn();
    }

    match /referrals/{uidParam} {
      allow read: if true;
      allow write: if ownsDoc(uidParam);
    }

    match /referral_clicks/{clickId} {
      allow create: if true;
      allow read: if false;
    }

    match /referral_signups/{signupId} {
      allow create: if signedIn();
      allow read: if signedIn();
    }

    match /referral_bonuses/{bonusId} {
      allow read, write: if signedIn();
    }

    match /staff_shifts/{shiftId} {
      allow read: if true;
      allow create: if ownsBusinessData(request.resource.data);
      allow update, delete: if ownsBusinessData(resource.data);
    }

    match /share_events/{eventId} {
      allow create: if true;
      allow read: if false;
    }
  }
}
