# Normalize line endings to LF on checkout
* text=auto eol=lf

# PHP files
*.php text eol=lf
*.phtml text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.svg text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Config/scripts
*.sh text eol=lf
*.env text eol=lf
Makefile text eol=lf
.htaccess text eol=lf

# Docs
*.md text eol=lf
*.txt text eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.pdf binary
*.zip binary
*.gz binary
*.phar binary

# Diff drivers
*.php diff=php
*.md diff=markdown

# Export-ignore (not included in git archive / dist)
.gitattributes export-ignore
.gitignore export-ignore
.editorconfig export-ignore
phpcs.xml export-ignore
phpstan.neon export-ignore
docker-compose*.yml export-ignore
Dockerfile export-ignore
Makefile export-ignore
tests/ export-ignore
